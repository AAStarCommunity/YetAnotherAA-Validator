data/*

# Private keys directory (contains sensitive BLS private keys)
.keys/
.agent/
.env

# Node development config files
node_dev_*.json
!node_dev_001.json

# Node state files (contains private keys)
# node_state.json — committed intentionally for Render deployment (ephemeral filesystem)

# Dependencies
node_modules/

dist/

# IDE
.vscode/

# CodeGraph local index (per-machine, rebuilt via `codegraph init -i`)
.codegraph/

# DVT e2e runtime (keys/logs/pids)
.e2e/

# notification contacts (per-account chat ids / emails — never commit)
notify-contacts.json

# env / secrets
.env.sepolia
.env.*
.env*.local

# Testnet deploy secrets (BLS keys + tunnel token / RPC)
deploy/node*/node_state.json
deploy/.env.testnet
deploy/.cf-run-token
deploy/.run/
