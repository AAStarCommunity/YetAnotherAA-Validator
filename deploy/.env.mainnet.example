# Production (mainnet) DVT config — copy to deploy/.env.mainnet and fill in.
# deploy/.env.mainnet is git-ignored (never commit RPC keys, PKs, or tunnel tokens).
# See docs/PRODUCTION_DEPLOYMENT.md for the full runbook + test↔prod differences.
#
# ⚠️ PRODUCTION = real money. Every value below must be the RELIABLE version, not
# the "good enough for testnet" one (dedicated RPC, isolated funded keys, policy ON).

# --- Chain (required) — fill from your mainnet contract deployment ---
# Use a DEDICATED paid RPC (Alchemy/Infura paid, or self-hosted node). A flaky RPC
# that doesn't propagate txs caused a 10h mempool stall on testnet — do not repeat.
ETH_RPC_URL=https://<your-dedicated-mainnet-rpc>
VALIDATOR_CONTRACT_ADDRESS=0x<mainnet AAStarValidator / AAStarBLSAlgorithm>
# EntryPoint v0.7 — same address across all chains
ENTRY_POINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# Admin/registration key — used once for registerPublicKey, then keep cold/offline.
# ETH_PRIVATE_KEY=0x<registration key, can be offline after registration>

# --- Policy gate (independent 2nd factor) — recommended ON for production ---
POLICY_ENABLED=true
POLICY_REGISTRY_ADDRESS=0x<mainnet PolicyRegistry>
# POLICY_PER_TX_MAX_WEI=<optional per-tx cap>
# POLICY_RECIPIENT_ALLOWLIST=0x...,0x...   # optional

# --- Per-IP rate limiting — recommended ON for production ---
RATE_LIMIT_ENABLED=true
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=30

# --- Out-of-band notification / confirmation (optional, recommended for high value) ---
# NOTIFY_ENABLED=true
# TELEGRAM_BOT_TOKEN=<...>
# NOTIFY_CONTACTS_FILE=deploy/node1/contacts.json
# CONFIRM_ENABLED=true
# CONFIRM_THRESHOLD_WEI=<withhold high-value ops above this until approved>

# --- Price Keeper (#58) ---
# Use a DEDICATED KEEPER_PRIVATE_KEY per node (funded with mainnet ETH), SEPARATE
# from RELAY_OPERATOR_PK (PR #105 isolates their nonce queues). Pre-submit static-sim
# + fee bump are built in. On mainnet, redundant updates cost REAL gas — prefer a
# single active keeper + standby, or assign each paymaster to one node (see runbook §6).
KEEPER_ENABLED=true
# KEEPER_PRIVATE_KEY=0x<dedicated funded key — NOT the relay key>   (put in deploy/node$i/.env)
KEEPER_PAYMASTER_ADDRESS=0x<mainnet SuperPaymaster>,0x<mainnet community PaymasterV4>
KEEPER_CHAINLINK_FEED=0x<mainnet ETH/USD feed>
# KEEPER_INTERVAL_MS=60000
# KEEPER_REFRESH_BUFFER_S=300
# KEEPER_MAX_UPDATES_PER_DAY=48
# KEEPER_MAX_BASE_FEE_GWEI=<set for mainnet gas, e.g. 30>

# --- Gasless purchase relay (#98) ---
# RELAY_OPERATOR_PK per node MUST be a DEDICATED funded hot wallet, whitelisted on the
# mainnet BuyHelper (isRelayer=true), kept off the validator-owner key. Production
# should also add a pre-submit eth_call preflight to avoid burning real gas on
# reverting buys (runbook §6).
RELAY_ENABLED=true
# RELAY_OPERATOR_PK=0x<dedicated funded hot-wallet key>   (put in deploy/node$i/.env)
# RELAY_RPC_URL=                       # defaults to ETH_RPC_URL
# RELAY_CHAIN_ID=<1 or 10 ...>
RELAY_BUY_HELPER=0x<mainnet BuyHelper (onlyRelayer, whitelists our operators)>
RELAY_USDC=0x<mainnet USDC>
RELAY_GTOKEN=0x<mainnet GToken>
RELAY_APNTS=0x<mainnet aPNTs>
# RELAY_MAX_PAYMENT_USDC=<per-tx cap, 6-decimal USDC>
# RELAY_RATE_LIMIT_PER_ADDRESS_PER_HOUR=5
# RELAY_RATE_LIMIT_GLOBAL_PER_HOUR=100

# --- Cloudflare named tunnel (stable public endpoint) ---
CLOUDFLARE_TUNNEL_TOKEN=<named-tunnel token>

# --- Public URLs each node advertises (your production hostnames) ---
NODE1_PUBLIC_URL=https://dvt1.aastar.io
NODE2_PUBLIC_URL=https://dvt2.aastar.io
NODE3_PUBLIC_URL=https://dvt3.aastar.io
